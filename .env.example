# If unset, a key is generated on first boot and printed once to the startup log.
# Once set here, this is the ONLY valid key — see docs/DESIGN.md §5 for why.
SPENDGAUGEAI_API_KEY=

# Optional — Discord webhook URL for budget/spike/digest alerts. No-op if unset.
DISCORD_WEBHOOK_URL=

# Optional — defaults shown.
HOST=0.0.0.0
PORT=8000
SPENDGAUGEAI_DB_PATH=./data/spendgaugeai.db
